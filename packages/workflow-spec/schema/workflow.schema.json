{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-reliability-platform.local/schema/workflow.schema.json",
  "title": "Agent Reliability Platform Workflow Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflow"],
  "properties": {
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "slug",
        "domain",
        "version",
        "description",
        "prompt_template",
        "input_schema",
        "output_schema",
        "model",
        "tools",
        "policies",
        "guardrails"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "minLength": 1,
          "maxLength": 120
        },
        "domain": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "prompt_template": {
          "type": "string",
          "minLength": 1
        },
        "input_schema": {
          "type": "object"
        },
        "output_schema": {
          "type": "object"
        },
        "model": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider", "name", "temperature"],
          "properties": {
            "provider": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            },
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            },
            "temperature": {
              "type": "number",
              "minimum": 0,
              "maximum": 2
            },
            "max_output_tokens": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "tools": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 120
                  },
                  "connector_id": {
                    "type": "string",
                    "format": "uuid"
                  }
                }
              }
            ]
          }
        },
        "policies": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "when", "action"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              },
              "when": {
                "type": "string",
                "minLength": 1
              },
              "action": {
                "type": "string",
                "enum": ["allow", "deny", "require_approval"]
              },
              "approver_role": {
                "type": "string",
                "enum": [
                  "platform_admin",
                  "org_admin",
                  "project_admin",
                  "ai_engineer",
                  "supervisor",
                  "team_lead",
                  "operator",
                  "analyst",
                  "api_client"
                ]
              }
            }
          }
        },
        "guardrails": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rollout": {
          "type": "object",
          "additionalProperties": false,
          "required": ["strategy"],
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["direct", "canary", "shadow", "ab_compare"]
            },
            "baseline_version": {
              "type": "string",
              "minLength": 1
            },
            "candidate_version": {
              "type": "string",
              "minLength": 1
            },
            "traffic_split": {
              "type": "object",
              "additionalProperties": false,
              "required": ["baseline", "candidate"],
              "properties": {
                "baseline": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 100
                },
                "candidate": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 100
                }
              }
            },
            "rollback_thresholds": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "policy_violation_rate": {
                  "type": "number",
                  "minimum": 0
                },
                "schema_failure_rate": {
                  "type": "number",
                  "minimum": 0
                },
                "p95_latency_ms": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          }
        },
        "eval_dataset_bindings": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    }
  }
}
